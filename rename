import os

folder_path = r"D:\Europe Solar Panels\Dataset\T1_D5\masks"

for filename in os.listdir(folder_path):
    if filename.startswith("chip_"):
        new_name = filename.replace("chip_", "chip19_")
        
        old_path = os.path.join(folder_path, filename)
        new_path = os.path.join(folder_path, new_name)
        
        os.rename(old_path, new_path)

print("Renaming completed!")








#rename starting only 
import os

folder_path = r"D:\srikaran\water bodies\tile2\chips"

files = sorted([f for f in os.listdir(folder_path) if f.endswith(".tif")])

start_number = 300

for i, file in enumerate(files):
    new_name = f"chip_{start_number + i}.tif"
    
    old_path = os.path.join(folder_path, file)
    new_path = os.path.join(folder_path, new_name)
    
    os.rename(old_path, new_path)

print("Renaming completed!")
