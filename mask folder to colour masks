import os
import cv2
import numpy as np

# Input folder containing binary masks
input_folder = r"D:\BasemapModelsFolder\SeaShore\masks"

# Output folder
output_folder = r"D:\BasemapModelsFolder\SeaShore\BlueMasks"
os.makedirs(output_folder, exist_ok=True)

# Blue color (BGR format for OpenCV)
BLUE = (255, 0, 0)

for filename in os.listdir(input_folder):
    if filename.lower().endswith((".png", ".jpg", ".jpeg", ".tif", ".tiff")):
        input_path = os.path.join(input_folder, filename)

        # Read as grayscale
        mask = cv2.imread(input_path, cv2.IMREAD_GRAYSCALE)

        if mask is None:
            print(f"Skipped: {filename}")
            continue

        # Create black RGB image
        color_mask = np.zeros((mask.shape[0], mask.shape[1], 3), dtype=np.uint8)

        # Convert white pixels to blue
        color_mask[mask > 0] = BLUE

        # Save
        output_path = os.path.join(output_folder, os.path.splitext(filename)[0] + ".png")
        cv2.imwrite(output_path, color_mask)

        print(f"Converted: {filename}")

print("\nDone! All masks converted to blue.")
